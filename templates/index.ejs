<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <a href="/"><img src="./icons/revansh_logo.png" class="logo" alt="logo"></a>
    </header>
    <main>
      <div class="content">
        <h1>Создание события</h1>

        <div class="form-container">
          <form action="" method="post" class="form-post">
            <div class="form-content">
              <div class="event-name">
                <label for="event-name">Событие</label>
                <input type="text" name="event_name" id="event-name" />
              </div>

              <div class="date-container">
                <div class="date-start">
                  <label for="date-start">Дата начала</label>
                  <input type="date" name="date_start" id="date-start" />
                </div>

                <div class="date-end">
                  <label for="date-end">Дата окончания</label>
                  <input type="date" name="date_end" id="date-end" />
                </div>

                <div class="period">
                  <label for="period">Срок дествия</label>
                  <input type="number" name="period" id="period" min="0" />
                </div>

                <div class="weight">
                  <label for="weight">Сила влияния</label>
                  <select name="weight" id="weight">
                    <option value="low">Низкая</option>
                    <option value="medium">Средняя</option>
                    <option value="high">Высокая</option>
                  </select>
                </div>
              </div>

              <div class="categories">
                <label for="categories">Категории</label>
                <select name="categories" id="categories">
                <%categories.forEach((category)=>{%>
                  <option><%=category%></option>
                <%});%>
                </select>
              </div>

              <div class="comment">
                <label for="comment">Комментарий</label>
                <textarea name="comment" id="comment"></textarea>
              </div>
              <div class="btn-sumbit">
              </div>
            </div>
          </form>
        </div>
      </div>
    </main>
    <footer></footer>
    <script src="./js/index.js"></script>
  </body>
</html>
