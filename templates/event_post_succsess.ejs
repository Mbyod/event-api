<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <img src="./icons/revansh_logo.png" class="logo" alt="logo">
    </header>
    <main>
      <div class="content">
        <h1>Событие зарегистрировано</h1>
        <p><b>Событие: </b><%= data.event_name %></p>
        <p><b>Дата начала: </b><%= data.date_start %></p>
        <p><b>Дата окончания: </b><%= data.date_end %></p>
        <p><b>Период: </b><%= data.period %></p>
        <p><b>Сила влияния: </b><%= data.weight %></p>
        <p><b>Категории: </b><%= data.categories %></p>
        <p><b>Комментарий: </b><%= data.comment %></p>
      </div>
    </main>
    <footer></footer>
    <script src="./js/index.js"></script>
  </body>
</html>
